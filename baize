#!/usr/bin/env bash
set -euo pipefail

# Captured before the assignment right below reuses the same name for this
# build's own embedded version. bash re-runs this file from the top on
# every invocation, so an env override like `BAIZE_VERSION=v0.2.0 baize
# update` would otherwise be silently clobbered by the very next line
# before resolve_latest_version ever saw it. See resolve_latest_version.
BAIZE_VERSION_PIN="${BAIZE_VERSION:-}"

BAIZE_VERSION="0.1.0"
BAIZE_REPO="Dylan0203/baize"

# --- Path resolution -------------------------------------------------------
# Resolved from $HOME at call time (never at source time), so tests can move
# HOME after sourcing. Honors XDG_CONFIG_HOME / XDG_STATE_HOME when set.

config_dir() { printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/baize"; }
state_dir()  { printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}/baize"; }
config_file() { printf '%s\n' "$(config_dir)/config"; }
state_file()  { printf '%s\n' "$(state_dir)/state"; }
bin_path()    { printf '%s\n' "$HOME/.local/bin/baize"; }

# --- Config loader -----------------------------------------------------------
# Sets globals: DSN MOUNTS THRESHOLD RESTATE_HOURS HEARTBEAT_URL INTERVAL
#
# Defaults live here; the config file (if present) overrides them via `.`.
# A config missing keys must still work. DSN is the only required key, but
# load_config does NOT enforce it -- `baize check` is useful without a DSN,
# and `install` is what writes the DSN. Enforcing it is require_dsn's job.
#
# INTERVAL is install-only metadata (it drives the cron schedule, nothing
# else reads it at runtime) but it is persisted here anyway so a re-install
# that doesn't pass --interval keeps the previous schedule instead of
# silently reverting to the default -- the same "flag -> existing config ->
# default" rule every other install flag follows.
load_config() {
  DSN=""
  MOUNTS="/"
  THRESHOLD=85
  RESTATE_HOURS=24
  HEARTBEAT_URL=""
  INTERVAL="15m"

  local cf; cf="$(config_file)"
  if [[ -f "$cf" ]]; then
    # shellcheck disable=SC1090  # path is runtime-resolved by design
    . "$cf"
  fi
}

# Errors actionably when DSN is empty. Callers that need a DSN call this
# after load_config; load_config itself never enforces it.
require_dsn() {
  if [[ -z "${DSN:-}" ]]; then
    cat >&2 <<'EOF'
baize: no DSN configured.
  Expected DSN in ~/.config/baize/config
  Run: baize install --dsn https://<key>@glitchtip.example.com/<project_id>
EOF
    return 1
  fi
}

# --- The three seams ---------------------------------------------------------
# Thin wrappers so bats stubs can intercept them. Disk logic and HTTP bodies
# arrive in later tasks.

# Current Unix epoch seconds on stdout.
now_epoch() { date +%s; }

# Used percentage (integer, no % sign) for mount $1 on stdout.
# Returns non-zero if the mount cannot be read or the output cannot be parsed.
#
# -P selects POSIX output format, which guarantees one line per filesystem;
# without it, a long device name wraps onto a second line and the capacity
# column shifts to the wrong row on hosts with long device paths.
disk_used_pct() {
  local mount="$1" out pct
  out="$(df -P "$mount" 2>/dev/null)" || return 1
  pct="$(printf '%s\n' "$out" | awk 'NR==2 {gsub(/%/,"",$5); print $5}')"
  # A df that prints a warning, an empty table, or a "-" capacity must fail
  # loudly here rather than let an empty string reach a numeric comparison.
  [[ "$pct" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$pct"
}

# Prints "<mount> <pct>" per readable mount in MOUNTS. Unreadable mounts warn
# on stderr and are skipped -- one vanished mount must not stop the others
# from being checked.
each_mount_pct() {
  local mount pct
  # shellcheck disable=SC2086  # MOUNTS is space-separated by design
  for mount in $MOUNTS; do
    if pct="$(disk_used_pct "$mount")"; then
      printf '%s %s\n' "$mount" "$pct"
    else
      printf 'baize: cannot read disk usage for mount: %s\n' "$mount" >&2
    fi
  done
}

# POST $2 (body, may be empty) to URL $1 with Content-Type $3 (default
# application/json). Non-zero on failure. Never prints secrets.
#
# --max-time bounds a hung TLS connection so a cron process never survives
# until the next one starts. -f turns an HTTP error status into a non-zero
# exit. -o /dev/null keeps the response body out of cron mail. $url is never
# logged here or by any caller -- it carries ?sentry_key=; error messages say
# "failed to send event to GlitchTip", never the URL.
http_post() {
  local url="$1" body="$2" ctype="${3:-application/json}"
  printf '%s' "$body" | curl -sS -f -X POST \
    -H "Content-Type: $ctype" \
    --max-time 10 \
    --data-binary @- \
    -o /dev/null \
    "$url"
}

# --- Shared helpers ----------------------------------------------------------

# This host's short name, on stdout. Never fails.
server_name() {
  hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'unknown\n'
}

# RFC 3339 UTC timestamp for epoch seconds $1 (defaults to now), on stdout.
# now_epoch is the only seam that ever calls `date`; this converts in pure
# bash so nothing bypasses the test stub and reintroduces real wall-clock time.
epoch_to_rfc3339() {
  local epoch="${1:-$(now_epoch)}"
  TZ=UTC printf '%(%Y-%m-%dT%H:%M:%SZ)T\n' "$epoch"
}

# --- GlitchTip envelope --------------------------------------------------------

# Parses a GlitchTip DSN "https://<key>@host/<project_id>".
# Sets globals: DSN_KEY DSN_HOST DSN_PROJECT. Returns non-zero on a malformed
# DSN. https-only, not https? -- the DSN GlitchTip issues is always https, so
# a one-character typo that produced an http:// URL would ship alerts in
# plaintext to a port GlitchTip probably is not even listening on, and baize
# has no way to tell "rejected" from "nobody home". Reject loudly instead.
parse_dsn() {
  local dsn="$1"
  [[ "$dsn" =~ ^https://([^@/]+)@([^/]+)/([0-9]+)/?$ ]] || return 1
  DSN_KEY="${BASH_REMATCH[1]}"
  DSN_HOST="${BASH_REMATCH[2]}"
  DSN_PROJECT="${BASH_REMATCH[3]}"
}

# 32 lowercase hex characters, no dashes, on stdout.
# uuidgen is not guaranteed on a minimal Ubuntu host; /proc/sys/kernel/random/uuid
# and /dev/urandom always are, so this needs neither uuidgen nor a new dependency.
new_event_id() {
  if [[ -r /proc/sys/kernel/random/uuid ]]; then
    tr -d '-' < /proc/sys/kernel/random/uuid
    printf '\n'
  else
    od -An -tx1 -N16 /dev/urandom | tr -d ' \n'
    printf '\n'
  fi
}

# Escapes $1 for embedding in a JSON string literal (no surrounding quotes).
# There is no jq on the target hosts, so every interpolated string must be
# escaped here or a mount/host name containing a quote produces a malformed
# envelope that GlitchTip silently rejects. Backslash must be escaped first,
# or the later replacements' own backslashes get double-escaped.
json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\r'/\\r}"
  printf '%s' "$s"
}

# send_event <level> <type> <value> <fingerprint_prefix> <mount> [extra_json]
#   level               warning | info | error
#   type                exception type, becomes the issue title prefix (e.g. DiskUsageHigh)
#   value               exception value, the human-readable half of the title
#   fingerprint_prefix  disk-breach | disk-recovery | baize-test | baize-removed
#   mount               the mount this concerns, or "-" when not mount-specific
#   extra_json          optional pre-built JSON object body for "extra", without
#                       braces, e.g. '"used_pct":88,"threshold_pct":85'. When
#                       omitted, the "extra" key is left out of the payload
#                       entirely -- not "extra":{}, and above all not a bare
#                       "extra": with nothing after it, which is malformed
#                       JSON that GlitchTip rejects while baize reports success.
# Returns non-zero if the event could not be sent.
#
# The fingerprint is ["<prefix>", "<server_name>", "<mount>"] -- the exact
# reason repeats collapse into one issue instead of hundreds. The percentage
# belongs in tags/extra/value, never the fingerprint.
send_event() {
  local level="$1" type="$2" value="$3" fp_prefix="$4" mount="$5" extra_json="${6:-}"

  parse_dsn "$DSN" || {
    printf 'baize: DSN is malformed, expected https://<key>@host/<project_id>\n' >&2
    return 1
  }

  local host; host="$(server_name)"
  # Computed once and reused for both the envelope header and the event
  # payload, so sent_at and timestamp can never disagree.
  local ts; ts="$(epoch_to_rfc3339)"
  local event_id; event_id="$(new_event_id)"

  local extra_field=""
  [[ -n "$extra_json" ]] && extra_field=",\"extra\":{$extra_json}"

  # Exactly one line, no embedded newlines -- the envelope's item header
  # omits "length", so the payload runs to the next newline.
  local event_json
  event_json="{\"event_id\":\"$event_id\",\"timestamp\":\"$ts\",\"platform\":\"other\",\"level\":\"$level\",\"logger\":\"baize\",\"server_name\":\"$(json_escape "$host")\",\"release\":\"baize@$BAIZE_VERSION\",\"fingerprint\":[\"$(json_escape "$fp_prefix")\",\"$(json_escape "$host")\",\"$(json_escape "$mount")\"],\"tags\":{\"host\":\"$(json_escape "$host")\",\"mount\":\"$(json_escape "$mount")\"},\"exception\":{\"values\":[{\"type\":\"$(json_escape "$type")\",\"value\":\"$(json_escape "$value")\"}]}$extra_field}"

  # $(...) strips all trailing newlines, so the trailing newline after the
  # last item is built with the printf format ending mid-line and appended
  # back explicitly, rather than lost to the substitution.
  local envelope
  envelope="$(printf '%s\n%s\n%s' \
    "{\"event_id\":\"$event_id\",\"sent_at\":\"$ts\"}" \
    '{"type":"event","content_type":"application/json"}' \
    "$event_json")"
  envelope+=$'\n'

  local url="https://$DSN_HOST/api/$DSN_PROJECT/envelope/?sentry_key=$DSN_KEY"

  if ! http_post "$url" "$envelope" "application/x-sentry-envelope"; then
    printf 'baize: failed to send event to GlitchTip\n' >&2
    return 1
  fi
}

# --- State machine ------------------------------------------------------------
# ~/.local/state/baize/state -- one line per mount, space-separated:
#   <mount> <level> <last_sent_epoch>
# <level> is "ok" or "breach"; <last_sent_epoch> is Unix seconds or 0.

# Prints "<level> <last_sent_epoch>" for mount $1. Prints "ok 0" when unknown.
read_state() {
  local mount="$1" sf line
  sf="$(state_file)"
  [[ -r "$sf" ]] || { printf 'ok 0\n'; return 0; }
  line="$(awk -v m="$mount" 'BEGIN {found=0} $1 == m {print $2, $3; found=1} END {if (!found) print "ok", 0}' "$sf")"
  printf '%s\n' "$line"
}

# Warns on stderr that the state file could not be written. Never fails the
# run -- baize's job is alerting, not bookkeeping.
warn_state() {
  printf 'baize: could not write state file %s -- state unchanged, next run will retry\n' "$(state_file)" >&2
}

# Sets mount $1 to level $2 with last_sent $3, preserving other mounts' lines.
write_state() {
  local mount="$1" level="$2" sent="$3" sf tmp
  sf="$(state_file)"
  mkdir -p "$(dirname "$sf")" 2>/dev/null || { warn_state; return 0; }
  tmp="$(mktemp "${sf}.XXXXXX" 2>/dev/null)" || { warn_state; return 0; }
  if { [[ -r "$sf" ]] && awk -v m="$mount" '$1 != m' "$sf"; printf '%s %s %s\n' "$mount" "$level" "$sent"; } > "$tmp" \
    && mv -f "$tmp" "$sf"; then
    return 0
  fi
  rm -f "$tmp"
  warn_state
  return 0
}

# decide_action <pct> <threshold> <level> <last_sent> <now> <restate_hours>
# Prints exactly one of: breach | restate | recovery | none
#
# The threshold is >=, not >: THRESHOLD=85 means 85% alerts.
#
# The state update that pairs with each action (applied by the caller, only
# after a successful send -- a failed send must leave state untouched so the
# next run retries):
#   breach   -> level=breach, last_sent=now
#   restate  -> level=breach, last_sent=now
#   recovery -> level=ok,     last_sent=0
#   none     -> unchanged
decide_action() {
  local pct="$1" threshold="$2" level="$3" last_sent="$4" now="$5" restate_hours="$6"
  local over=0
  (( pct >= threshold )) && over=1

  if (( over == 1 )); then
    if [[ "$level" != "breach" ]]; then
      printf 'breach\n'
    elif (( now - last_sent >= restate_hours * 3600 )); then
      printf 'restate\n'
    else
      printf 'none\n'
    fi
  else
    if [[ "$level" == "breach" ]]; then
      printf 'recovery\n'
    else
      printf 'none\n'
    fi
  fi
}

# --- Install: config rendering, interval parsing, crontab marker block --------

# The annotated config body for the *current* values of DSN MOUNTS THRESHOLD
# RESTATE_HOURS HEARTBEAT_URL INTERVAL, on stdout. This is the single
# generator for ~/.config/baize/config -- cmd_install always rewrites the
# whole file from this, never appends, so a re-install can't accumulate
# duplicate keys where the last one silently wins. Keep the comments here in
# sync with config.example by hand; config.example is dev-only documentation
# and is never shipped to a host, so it cannot be read back at install time.
render_config() {
  cat <<EOF
# baize config -- ~/.config/baize/config
# Written by \`baize install\`; hand-editing is fine, this file is never
# touched by \`baize update\`. Shell KEY=VALUE, sourced with \`.\`.

# GlitchTip DSN -- https://<public_key>@glitchtip.example.com/<project_id>
DSN="$DSN"

# Space-separated mount points to watch.
MOUNTS="$MOUNTS"

# Alert when used percentage is >= this. Must be an integer 1-99.
THRESHOLD=$THRESHOLD

# While still breached, re-send an event this often (hours).
RESTATE_HOURS=$RESTATE_HOURS

# Optional GlitchTip heartbeat check-in URL. Empty/unset = heartbeat disabled.
HEARTBEAT_URL="$HEARTBEAT_URL"

# How often cron invokes \`baize run\`. <N>m where N divides 60 evenly
# (1 2 3 4 5 6 10 12 15 20 30), or <N>h where N divides 24 evenly
# (1 2 3 4 6 8 12). Anything else is rejected at install time -- an interval
# that doesn't divide its unit evenly (e.g. */7) silently drifts the
# schedule instead of firing at a constant period.
INTERVAL="$INTERVAL"
EOF
}

# Cron schedule for interval string $1 (e.g. "15m", "6h"), on stdout.
#   "15m" -> "*/15 * * * *"   "1h" -> "0 * * * *"   "6h" -> "0 */6 * * *"
# Only minute values that divide 60 evenly and hour values that divide 24
# evenly are accepted -- e.g. "*/7 * * * *" fires at :00 :07 ... :56 and
# then :00 again, a 4-minute gap at the top of every hour. An interval that
# lies about its own period is rejected rather than silently honored.
# Prints nothing and returns non-zero, with the accepted values listed on
# stderr, for anything else.
cron_schedule_from_interval() {
  local interval="$1" n

  if [[ "$interval" =~ ^([0-9]+)m$ ]]; then
    n="${BASH_REMATCH[1]}"
    case "$n" in
      1) printf '* * * * *\n'; return 0 ;;
      2|3|4|5|6|10|12|15|20|30) printf '*/%s * * * *\n' "$n"; return 0 ;;
    esac
  elif [[ "$interval" =~ ^([0-9]+)h$ ]]; then
    n="${BASH_REMATCH[1]}"
    case "$n" in
      1) printf '0 * * * *\n'; return 0 ;;
      2|3|4|6|8|12) printf '0 */%s * * *\n' "$n"; return 0 ;;
    esac
  fi

  printf 'baize: invalid --interval: %s\n  Accepted minute values: 1 2 3 4 5 6 10 12 15 20 30 (e.g. 15m)\n  Accepted hour values:   1 2 3 4 6 8 12 (e.g. 6h)\n' "$interval" >&2
  return 1
}

# Prints the current crontab, or nothing if there is none. `crontab -l`
# exits non-zero when there is no crontab at all, which under `set -euo
# pipefail` would abort the install on a fresh box -- the `|| true` is
# load-bearing, not decoration.
read_crontab() { crontab -l 2>/dev/null || true; }

# Replaces (or inserts) the baize marker block; everything outside the
# markers is byte-identical. This is the only function that touches the
# crontab, so the marker-block logic lives in exactly one readable place.
#
# Blank lines are NOT filtered globally -- a `grep -v '^$'` here would strip
# every blank line in the user's crontab, including ones they put between
# their own entries for readability. The only blank worth removing is a
# single leading one that appears when $current was empty, hence
# `sed '1{/^$/d}'` rather than a global purge.
#
# An empty $block (what `remove` passes) removes the baize block entirely.
# That case is written separately from the non-empty case below: piping
# "$stripped\n$block\n" through with an empty $block always appends one
# extra trailing blank line, which would leave the user's surviving lines
# not-quite-byte-identical. $stripped/$out already carry no trailing
# newline (command substitution strips it), so a plain `printf '%s\n'`
# reattaches exactly one -- or, if nothing survived at all, writes a fully
# empty crontab instead of a stray blank line.
write_crontab_block() {
  local block="$1" current stripped out
  current="$(read_crontab)"
  stripped="$(printf '%s\n' "$current" | awk '
    /^# BEGIN baize$/ {skip=1; next}
    /^# END baize$/   {skip=0; next}
    !skip
  ')"
  if [[ -n "$block" ]]; then
    # The trailing ";" before the closing brace is needed for BSD sed
    # (macOS dev machines); GNU sed (the Ubuntu target) accepts it
    # identically.
    out="$(printf '%s\n%s\n' "$stripped" "$block" | sed '1{/^$/d;}')"
  else
    out="$stripped"
  fi
  if [[ -n "$out" ]]; then
    printf '%s\n' "$out" | crontab -
  else
    printf '' | crontab -
  fi
}

# The "# BEGIN baize" .. "# END baize" block for the current INTERVAL, on
# stdout. Uses the expanded absolute path from bin_path, not "$HOME/..." --
# cron's environment is not a login shell, and while $HOME is set there,
# relying on it buys nothing and only surprises whoever reads `crontab -l`.
# No PATH= line is added: cron's PATH (typically /usr/bin:/bin) already
# covers curl/df/sha256sum/date/hostname on Ubuntu, so one would be
# speculative.
cron_block() {
  local schedule
  schedule="$(cron_schedule_from_interval "$INTERVAL")" || return 1
  printf '# BEGIN baize\n%s %s run\n# END baize' "$schedule" "$(bin_path)"
}

# `baize install [--dsn URL] [--threshold N] [--interval Nm|Nh] [--heartbeat URL] [--dry-run]`
#
# Merge order per key is flag -> existing config -> built-in default:
# load_config first populates existing-or-default, then flags override, then
# the whole file is rewritten from the resolved values. Never appended --
# appending is how repeated installs end up with duplicate keys where the
# last one silently wins.
cmd_install() {
  local dsn="" threshold="" interval="" heartbeat="" dry_run=0
  local dsn_given=0 threshold_given=0 interval_given=0 heartbeat_given=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dsn|--threshold|--interval|--heartbeat)
        if [[ $# -lt 2 ]]; then
          printf 'baize install: %s requires a value\n' "$1" >&2
          return 2
        fi
        case "$1" in
          --dsn)       dsn="$2";       dsn_given=1 ;;
          --threshold) threshold="$2"; threshold_given=1 ;;
          --interval)  interval="$2";  interval_given=1 ;;
          --heartbeat) heartbeat="$2"; heartbeat_given=1 ;;
        esac
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      *)
        printf 'baize install: unknown flag: %s\n  Valid flags: --dsn --threshold --interval --heartbeat --dry-run\n' "$1" >&2
        return 2
        ;;
    esac
  done

  load_config
  [[ "$dsn_given" -eq 1 ]]       && DSN="$dsn"
  [[ "$threshold_given" -eq 1 ]] && THRESHOLD="$threshold"
  [[ "$interval_given" -eq 1 ]]  && INTERVAL="$interval"
  [[ "$heartbeat_given" -eq 1 ]] && HEARTBEAT_URL="$heartbeat"

  # --- Validate up front; every error names the fix. ---
  if [[ -z "$DSN" ]]; then
    printf 'baize install: --dsn is required on first install\n  Example: baize install --dsn https://<key>@glitchtip.example.com/<project_id>\n' >&2
    return 1
  fi
  if ! [[ "$DSN" =~ ^https://[^@[:space:]/]+@[^/[:space:]]+/[0-9]+/?$ ]]; then
    printf 'baize install: malformed --dsn: %s\n  Expected: https://<public_key>@glitchtip.example.com/<project_id>\n' "$DSN" >&2
    return 1
  fi
  if ! [[ "$THRESHOLD" =~ ^[0-9]+$ ]] || (( THRESHOLD < 1 || THRESHOLD > 99 )); then
    printf 'baize install: --threshold must be an integer between 1 and 99, got: %s\n' "$THRESHOLD" >&2
    return 1
  fi
  local schedule
  schedule="$(cron_schedule_from_interval "$INTERVAL")" || return 1
  if [[ -z "$MOUNTS" ]]; then
    printf 'baize install: MOUNTS is empty; set at least one mount point in %s\n' "$(config_file)" >&2
    return 1
  fi

  local body block cfile
  body="$(render_config)"
  block="$(cron_block)"
  cfile="$(config_file)"

  if [[ "$dry_run" -eq 1 ]]; then
    printf '%s\n' "$body"
    printf '%s %s run\n' "$schedule" "$(bin_path)"
    return 0
  fi

  # holds the DSN key, hence 700/600 rather than the more usual 755/644.
  mkdir -p "$(config_dir)"
  chmod 700 "$(config_dir)"
  printf '%s\n' "$body" > "$cfile"
  chmod 600 "$cfile"

  mkdir -p "$(state_dir)"

  write_crontab_block "$block"

  cat <<SUMMARY
baize installed.
  config:   $cfile
  state:    $(state_dir)
  schedule: $schedule ($(bin_path) run)

Next: baize test
SUMMARY
}

# --- Remove: farewell event, teardown, confirmation ---------------------------

# True if baize has anything installed to remove: the binary, baize.prev,
# the config dir, the state dir, or a crontab block. Lets `remove` on an
# already-clean box report "nothing to remove" and exit 0 without prompting
# for a destructive action that would not destroy anything.
anything_installed() {
  [[ -e "$(bin_path)" ]] && return 0
  [[ -e "$HOME/.local/bin/baize.prev" ]] && return 0
  [[ -d "$(config_dir)" ]] && return 0
  [[ -d "$(state_dir)" ]] && return 0
  read_crontab | grep -q '^# BEGIN baize$' && return 0
  return 1
}

# Prompts for confirmation on /dev/tty, never stdin -- `curl | bash` leaves
# stdin pointed at a pipe of script text, and a prompt reading stdin would
# either consume that text or see EOF and silently take the default. When
# there is no controlling terminal at all (a genuinely non-interactive
# context) this requires --force instead of guessing what a human would
# have answered. `{ exec 3<>/dev/tty; } 2>/dev/null` is the check: opening
# /dev/tty for read+write on fd 3 fails cleanly (no controlling terminal)
# without also killing the script the way a bare failed `exec` redirection
# can.
confirm_remove() {
  local force="$1" host reply

  [[ "$force" -eq 1 ]] && return 0

  if ! { exec 3<>/dev/tty; } 2>/dev/null; then
    printf 'baize remove: no controlling terminal to confirm on.\n  Re-run with --force to remove without prompting.\n' >&2
    return 2
  fi

  host="$(server_name)"
  {
    printf 'This will remove baize from %s:\n' "$host"
    printf '  cron entry, %s, %s/, %s/\n' "$(bin_path)" "$(config_dir)" "$(state_dir)"
    printf 'Continue? [y/N] '
  } >&3
  read -r reply <&3
  exec 3<&- 3>&-

  [[ "$reply" =~ ^[Yy]$ ]] || { printf 'Aborted.\n'; return 1; }
  return 0
}

# Best-effort farewell event, sent while the config still exists and before
# any teardown. This is the sharp edge of `remove`: it runs on boxes with no
# network, a revoked DSN, or a broken config, and must still let removal
# complete, so nothing in here is allowed to propagate a failure upward --
# every early exit is `return 0`, and the caller additionally wraps the
# call in `|| true`.
#
# The config file is syntax-checked with `bash -n` before it is ever
# sourced. `load_config`'s `. "$cf"` is what every other verb also uses,
# and that is fine for them -- but a config with a genuine bash syntax
# error makes `.` abort the whole process outright (a fatal parse error,
# not a normal non-zero exit `set -e`/`||` can trap), which here would take
# the removal down with it. `bash -n` only parses, never executes, so it
# can reject that file and let this function fall through to the
# no-announcement path instead.
say_goodbye() {
  local cf; cf="$(config_file)"
  if [[ -f "$cf" ]] && ! bash -n "$cf" 2>/dev/null; then
    printf 'Note: config file is malformed, skipping removal announcement (removing anyway).\n' >&2
    return 0
  fi

  load_config 2>/dev/null || return 0
  [[ -n "${DSN:-}" ]] || return 0

  if send_event info BaizeRemoved \
       "baize was removed from $(server_name)" \
       baize-removed "-" 2>/dev/null; then
    printf 'Announced removal to GlitchTip.\n'
  else
    printf 'Note: could not announce removal to GlitchTip (removing anyway).\n' >&2
  fi
  return 0
}

# Removes the crontab block -- first among the destructive steps, so that
# if anything after this fails, cron is at least no longer firing a
# half-removed baize every INTERVAL. write_crontab_block("") is exactly the
# "remove the block" case its own doc comment describes.
remove_cron_block() {
  write_crontab_block ""
}

# Removes every path baize owns. Order: state, then config (unless kept),
# then the previous-version binary, then the running script itself last --
# see cmd_remove for why last matters. rm -rf/-f only ever targets paths
# built fresh from bin_path/config_dir/state_dir/$HOME, never a bare
# "$SOME_VAR" that could be empty; cmd_remove has already refused to run
# with $HOME unset or empty, so these can never widen into "/".
remove_files() {
  local keep_config="$1"
  rm -rf "$(state_dir)"
  [[ "$keep_config" -eq 1 ]] || rm -rf "$(config_dir)"
  rm -f "$HOME/.local/bin/baize.prev"
  # Deleting the running script out from under itself is safe on Linux:
  # bash already holds baize open, and the inode -- along with every line
  # still to be read -- survives until this process exits, even though the
  # directory entry disappears the instant this command returns.
  rm -f "$(bin_path)"
}

# Reports what's left for the human. baize cannot delete its own GlitchTip
# heartbeat monitor -- that needs a write-scoped token, which v0.1
# deliberately refuses to put on a host -- so it tells the human instead.
# Printed only when a heartbeat was actually configured; telling someone to
# delete a monitor they never made is noise.
print_manual_followups() {
  local heartbeat_was_set="$1"
  printf 'Removed baize from %s.\n' "$(server_name)"
  if [[ "$heartbeat_was_set" -eq 1 ]]; then
    cat <<EOF

One thing left, in GlitchTip:
  Delete the Heartbeat monitor for this host (Organization Settings -> Uptime Monitors).
  If you leave it, it will alert in ~30 minutes because baize is no longer checking in.
EOF
  fi
}

# `baize remove [--force] [--keep-config]`
#
# Order: refuse on a broken $HOME -> confirm -> farewell (while config
# still exists) -> cron -> state -> config -> baize.prev -> the running
# script, last. The farewell is entirely best-effort (see say_goodbye) --
# a box with no network, a revoked DSN, or a broken config must still end
# up with baize fully removed.
cmd_remove() {
  if [[ -z "${HOME:-}" ]]; then
    printf 'baize remove: refusing to run with HOME unset or empty\n' >&2
    return 1
  fi

  local force=0 keep_config=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)       force=1; shift ;;
      --keep-config) keep_config=1; shift ;;
      *)
        printf 'baize remove: unknown flag: %s\n  Valid flags: --force --keep-config\n' "$1" >&2
        return 2
        ;;
    esac
  done

  if ! anything_installed; then
    printf 'baize: nothing to remove.\n'
    return 0
  fi

  confirm_remove "$force" || return $?

  say_goodbye || true   # best-effort, always; never gates what follows

  # say_goodbye's own load_config call (or its no-op default when there is
  # no config to load) leaves HEARTBEAT_URL populated as a side effect --
  # captured here, before teardown removes the config it came from, rather
  # than loading a second time.
  local heartbeat_was_set=0
  [[ -n "${HEARTBEAT_URL:-}" ]] && heartbeat_was_set=1

  remove_cron_block
  remove_files "$keep_config"
  print_manual_followups "$heartbeat_was_set"
}

# --- Verb stubs ---------------------------------------------------------------
# Real behavior arrives in later tasks. Each stub keeps this file lint-clean
# and gives those tasks a defined slot to fill.

# Human-facing report: prints per-mount usage and OVER/ok status. Sends
# nothing -- no event, no heartbeat -- so a human debugging at the terminal
# can never trigger an alert or fake a check-in that masks a real outage.
# Exits 0 even when a mount is over threshold; it reports, it does not
# judge. Exits 1 only when MOUNTS yields nothing readable at all -- that is
# a broken config, not a healthy disk.
cmd_check() {
  load_config

  local mount pct label found=0
  while read -r mount pct; do
    found=1
    if (( pct >= THRESHOLD )); then
      label="OVER"
    else
      label="ok"
    fi
    printf '%-12s%3s%%  %-4s (threshold %s%%)\n' "$mount" "$pct" "$label" "$THRESHOLD"
  done < <(each_mount_pct)

  if [[ "$found" -eq 0 ]]; then
    printf 'baize: no readable mounts (checked: %s)\n' "$MOUNTS" >&2
    return 1
  fi
}

# Best-effort check-in. Never fails the run -- the heartbeat is how
# GlitchTip learns baize is alive, and failing the run over it would be the
# monitor killing itself over its own status report.
send_heartbeat() {
  [[ -n "${HEARTBEAT_URL:-}" ]] || return 0
  # The check-in endpoint takes an empty body and does not care about
  # Content-Type; this is passed only because http_post requires one.
  if ! http_post "$HEARTBEAT_URL" "" "application/json"; then
    printf 'baize: heartbeat check-in failed\n' >&2
  fi
  return 0
}

# The cron verb: check, alert only on transitions, heartbeat unconditionally.
# Quiet on success -- cron mails any output, and a monitor that mails every
# 15 minutes gets filtered into oblivion, taking the real alert with it.
#
# Three details that carry weight: state updates only on a successful send
# (a failed POST leaves state untouched so the next run retries); the
# while-read loop uses process substitution rather than a pipe, so its
# updates to `found`/`exit_code` survive outside a subshell; the heartbeat
# is last and unconditional -- it fires whether or not the mounts were
# readable and whether or not an event went out.
cmd_run() {
  load_config
  require_dsn || return 1

  local now; now="$(now_epoch)"
  local mount pct level last_sent action
  local found=0 exit_code=0

  while read -r mount pct; do
    found=1
    read -r level last_sent <<< "$(read_state "$mount")"
    action="$(decide_action "$pct" "$THRESHOLD" "$level" "$last_sent" "$now" "$RESTATE_HOURS")"
    case "$action" in
      breach|restate)
        if send_event warning DiskUsageHigh \
             "Disk usage ${pct}% on ${mount} (threshold ${THRESHOLD}%)" \
             disk-breach "$mount" "\"used_pct\":${pct},\"threshold_pct\":${THRESHOLD}"; then
          write_state "$mount" breach "$now"
        else
          exit_code=1
        fi
        ;;
      recovery)
        if send_event info DiskUsageRecovered \
             "Disk usage back to ${pct}% on ${mount} (threshold ${THRESHOLD}%)" \
             disk-recovery "$mount" "\"used_pct\":${pct},\"threshold_pct\":${THRESHOLD}"; then
          write_state "$mount" ok 0
        else
          exit_code=1
        fi
        ;;
      none) : ;;
    esac
  done < <(each_mount_pct)

  if [[ "$found" -eq 0 ]]; then
    printf 'baize: no readable mounts (checked: %s)\n' "$MOUNTS" >&2
    exit_code=1
  fi

  send_heartbeat

  return "$exit_code"
}

# Sends one baize-test event to prove the DSN and network path both work.
# This is the one verb whose whole purpose is proving the pipe works, so its
# failure must be loud and its success must tell the user where to look.
cmd_test() {
  load_config
  require_dsn || return 1
  if send_event info BaizeTest "baize test event from $(server_name)" baize-test "-"; then
    printf 'Sent test event. Check the host-monitoring project in GlitchTip.\n'
  else
    printf 'baize: failed to send test event. Check DSN and network.\n' >&2
    return 1
  fi
}

# --- Status: config, cron, last alert, disk, best-effort update check --------

# Cron status line for `status`: the schedule with "(active)" when baize's
# marker block is present in the crontab, or a loud "NOT SCHEDULED" when it
# is not. An installed-but-unscheduled baize is the precise silent failure
# this tool exists to prevent -- it looks installed and answers `version`,
# but alerts nobody -- so this must be impossible to miss when skimming.
cron_status_line() {
  local content middle schedule
  content="$(read_crontab)"
  middle="$(printf '%s\n' "$content" | awk '/^# BEGIN baize$/{f=1;next} /^# END baize$/{f=0} f')"
  if [[ -n "$middle" ]]; then
    schedule="$(awk '{print $1, $2, $3, $4, $5}' <<< "$middle")"
    printf '%s  (active)\n' "$schedule"
  else
    printf 'NOT SCHEDULED  <-- baize is installed but will never run\n'
  fi
}

# Human-readable relative time for a duration of $1 seconds, on stdout.
relative_time() {
  local diff="$1"
  if (( diff < 60 )); then
    printf '%d seconds ago\n' "$diff"
  elif (( diff < 3600 )); then
    printf '%d minutes ago\n' $(( diff / 60 ))
  elif (( diff < 86400 )); then
    printf '%d hours ago\n' $(( diff / 3600 ))
  else
    printf '%d days ago\n' $(( diff / 86400 ))
  fi
}

# "Last alert" line for `status`: the most recent last_sent across MOUNTS,
# or "never" when nothing has ever been sent.
#
# Labeled "Last alert", not "Last run": the state file records when an
# event was last *sent*, not when baize last executed. A host that ran 40
# times today and alerted zero times has a Last alert of "never", and that
# is correct -- calling it "Last run" would read as reassurance, which is
# exactly what let the disk fill silently in the first place. A true
# last-run timestamp would mean a disk write on every happy-path run; the
# heartbeat, not this line, is what proves baize is alive -- a deliberate
# non-goal (see docs/baize-v0-1 shared context).
last_alert_line() {
  local mount level last_sent max_last_sent=0
  # shellcheck disable=SC2086  # MOUNTS is space-separated by design
  for mount in $MOUNTS; do
    read -r level last_sent <<< "$(read_state "$mount")"
    (( last_sent > max_last_sent )) && max_last_sent=$last_sent
  done

  if (( max_last_sent == 0 )); then
    printf 'never\n'
    return 0
  fi

  local now diff ts
  now="$(now_epoch)"
  diff=$(( now - max_last_sent ))
  ts="$(epoch_to_rfc3339 "$max_last_sent")"
  ts="${ts/T/ }"
  ts="${ts%Z} UTC"
  printf '%s  (%s)\n' "$ts" "$(relative_time "$diff")"
}

# Human-facing report: config (redacted), cron state, last alert, and disk
# usage -- everything needed to answer "what is this host doing?" at a
# glance. Strictly read-only: `status` never writes to disk, never installs
# anything (BRIEF constraint #2 -- a `status` that installs is an
# auto-updater in disguise), and sends nothing -- no event, no heartbeat --
# so a human debugging at the terminal can never trigger an alert or fake a
# check-in that masks a real outage.
#
# Exits 0 whenever it can report, even when the news is bad (over
# threshold, not scheduled, update check failed). Exits non-zero only when
# there is no config at all -- the one case where the fix really is
# `baize install`.
cmd_status() {
  local cf; cf="$(config_file)"
  if [[ ! -f "$cf" ]]; then
    printf 'baize: no config found at %s\n  Run: baize install --dsn https://<key>@glitchtip.example.com/<project_id>\n' "$cf" >&2
    return 1
  fi

  load_config

  # --- Version / update check -------------------------------------------
  # Best-effort: `status` is often run precisely because the network is
  # broken, so a failed check must never fail the whole command -- it
  # prints "(update check unavailable)" and everything else still prints.
  # resolve_latest_version already caps itself at a 10s curl --max-time;
  # that is the only network call `status` ever makes.
  local version_line="baize $BAIZE_VERSION"
  local latest
  if latest="$(resolve_latest_version 2>/dev/null)"; then
    local latest_norm="${latest#v}"
    [[ "$latest_norm" != "$BAIZE_VERSION" ]] && version_line+="  (update available: $latest_norm)"
  else
    version_line+="  (update check unavailable)"
  fi
  printf '%s\n\n' "$version_line"

  # --- Config, redacted ---------------------------------------------------
  # DSN: rebuilt from parse_dsn's components rather than regex-replacing
  # the raw DSN, so a malformed DSN that doesn't match the expected shape
  # can never leak a key by falling through unredacted.
  local dsn_display="(none configured)"
  if [[ -n "$DSN" ]]; then
    if parse_dsn "$DSN"; then
      dsn_display="https://***@${DSN_HOST}/${DSN_PROJECT}"
    else
      dsn_display="(malformed)"
    fi
  fi
  # HEARTBEAT_URL is never printed, not even truncated -- that UUID is the
  # entire authentication for the check-in endpoint.
  local heartbeat_display="not configured"
  [[ -n "$HEARTBEAT_URL" ]] && heartbeat_display="configured"

  # The replacement's "~" must be backslash-escaped: unescaped, bash
  # tilde-expands it against the real OS home directory (a getpwnam
  # lookup), not against $HOME as reassigned for tests -- an unescaped
  # version passes every bats test (which never overrides getpwnam) yet
  # prints the wrong path on a real host.
  local cf_display="${cf/#$HOME/\~}"
  printf 'Config     %s\n' "$cf_display"
  printf '  DSN        %s\n' "$dsn_display"
  printf '  MOUNTS     %s\n' "$MOUNTS"
  printf '  THRESHOLD  %s%%\n' "$THRESHOLD"
  printf '  RESTATE    %sh\n' "$RESTATE_HOURS"
  printf '  HEARTBEAT  %s\n' "$heartbeat_display"
  printf '\n'

  # --- Cron and last alert ------------------------------------------------
  printf 'Cron       %s\n' "$(cron_status_line)"
  printf 'Last alert %s\n' "$(last_alert_line)"
  printf '\n'

  # --- Disk ----------------------------------------------------------------
  printf 'Disk\n'
  local mount pct label
  while read -r mount pct; do
    if (( pct >= THRESHOLD )); then label="OVER"; else label="ok"; fi
    printf '  %-10s %3s%%  %s\n' "$mount" "$pct" "$label"
  done < <(each_mount_pct)

  return 0
}

# --- Update: release resolution, verified atomic swap, rollback --------------

# Prints the latest release tag (e.g. "v0.2.0") on stdout. Honors an
# incoming BAIZE_VERSION environment variable as a pin, letting a human
# force a specific version without touching the API -- reads it via
# BAIZE_VERSION_PIN (captured at the very top of this file, before the
# BAIZE_VERSION constant below is assigned) rather than $BAIZE_VERSION
# itself, which by the time this runs always holds this build's own
# embedded version, not whatever a caller passed in the environment.
#
# Shared with install.sh, which resolves releases the same way, and with
# `baize status`'s update check, which is why this is its own function
# rather than inlined into cmd_update -- see docs/baize-v0-1 shared context
# on the paired-change surface: change one, mirror the other.
#
# No jq -- the host is not allowed to need one. Never falls back to raw
# `main`: a failed or unparseable API response is an error, not a silent
# downgrade to an unversioned build.
resolve_latest_version() {
  if [[ -n "$BAIZE_VERSION_PIN" ]]; then
    printf '%s\n' "$BAIZE_VERSION_PIN"
    return 0
  fi
  local json tag
  json="$(curl -fsSL --max-time 10 \
    "https://api.github.com/repos/${BAIZE_REPO}/releases/latest")" || return 1
  # `*`, not `+`, inside the capture: an empty "tag_name":"" must still
  # match (and then fail the emptiness check below), rather than leave the
  # whole substitution a no-op that falls through with $tag holding the
  # raw, unparsed JSON line -- which is non-empty and would otherwise sail
  # past the check that follows.
  tag="$(printf '%s\n' "$json" | grep -m1 '"tag_name"' \
    | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')"
  [[ -n "$tag" ]] || return 1
  printf '%s\n' "$tag"
}

# Filesystem device id for path $1, on stdout. GNU stat (Ubuntu, the
# target host) takes -c; BSD stat (macOS, where this test suite also runs)
# takes -f with an equivalent %d token, hence the fallback rather than one
# or the other. `stat` is not among the runtime tools this project
# otherwise allows itself -- it exists here only for update's
# same-filesystem guard below, and `update` is a human-invoked maintenance
# action, not the disk-check path that restriction protects.
fs_device_id() {
  stat -c '%d' "$1" 2>/dev/null || stat -f '%d' "$1" 2>/dev/null
}

# True if device ids $1 and $2 match. Split out from fs_device_id so the
# same-filesystem guard's comparison is unit-testable with plain strings,
# without needing two real filesystems in the test environment.
same_device() {
  [[ -n "$1" && "$1" == "$2" ]]
}

# Restores baize.prev over the current binary. The only path in `update`
# that could leave a host without a previously-proven-working baize if it
# did nothing -- so every post-swap failure calls this. cp, not mv:
# baize.prev must survive so a repeated failure can roll back again.
rollback_update() {
  if [[ -f "$HOME/.local/bin/baize.prev" ]]; then
    cp -f "$HOME/.local/bin/baize.prev" "$HOME/.local/bin/baize"
    printf 'baize: update failed; rolled back to the previous version.\n' >&2
  fi
  return 1
}

# `baize update [--force]`
#
# Every step gates the next; a failure at any point leaves the previously
# working ~/.local/bin/baize running, untouched. This is the only function
# in this file that writes to ~/.local/bin/baize, and it is reachable only
# through the verb dispatcher in main() -- never from cron, a timer, or
# cmd_run. `update` is explicit and human-typed, on purpose: an
# auto-updater would hand this component exactly the network dependency
# and remote-code-execution surface it exists to not have (BRIEF
# constraint #2). If that is not obvious from reading this file, this verb
# has failed regardless of what its tests say.
cmd_update() {
  local force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=1; shift ;;
      *)
        printf 'baize update: unknown flag: %s\n  Valid flags: --force\n' "$1" >&2
        return 2
        ;;
    esac
  done

  local target
  target="$(resolve_latest_version)" || {
    printf 'baize update: could not resolve the latest release. Check network and try again.\n' >&2
    return 1
  }
  local target_norm="${target#v}"

  if [[ "$target_norm" == "$BAIZE_VERSION" && "$force" -eq 0 ]]; then
    printf 'Already on %s\n' "$BAIZE_VERSION"
    return 0
  fi

  local install_dir; install_dir="$(dirname "$(bin_path)")"
  mkdir -p "$install_dir"

  # Next to the target, never /tmp: mv is an atomic rename only within one
  # filesystem, and /tmp is very often a separate filesystem or a tmpfs. A
  # failed update leaves a working baize; a torn swap across filesystems
  # might not.
  local tmp
  tmp="$(mktemp -d "$install_dir/.baize-update.XXXXXX")" || {
    printf 'baize update: could not create a temp dir under %s\n' "$install_dir" >&2
    return 1
  }
  # shellcheck disable=SC2064  # $tmp must be baked into the trap string now:
  # cmd_update returns rather than exits (see the shared bash conventions),
  # so by the time this trap actually fires at process exit, $tmp -- a
  # local variable -- would already be out of scope for a deferred
  # (single-quoted) expansion.
  trap "rm -rf '$tmp'" EXIT

  # $HOME is not sufficient on its own to guarantee this: ~/.local can be a
  # symlink to another mount, or $HOME itself a network mount with local
  # disk underneath. Assert same-filesystem rather than trust it, since a
  # wrong answer here is silent -- refusing beats a non-atomic swap.
  local tmp_dev install_dev
  tmp_dev="$(fs_device_id "$tmp")"
  install_dev="$(fs_device_id "$install_dir")"
  if ! same_device "$tmp_dev" "$install_dev"; then
    printf 'baize: temp dir is on a different filesystem; the swap would not be atomic.\n' >&2
    return 1
  fi

  if ! curl -fsSL --max-time 30 -o "$tmp/baize" \
       "https://github.com/$BAIZE_REPO/releases/download/$target/baize"; then
    printf 'baize update: could not download baize %s\n' "$target" >&2
    return 1
  fi
  if ! curl -fsSL --max-time 30 -o "$tmp/SHA256SUMS" \
       "https://github.com/$BAIZE_REPO/releases/download/$target/SHA256SUMS"; then
    printf 'baize update: could not download SHA256SUMS for %s\n' "$target" >&2
    return 1
  fi

  # `sha256sum -c --ignore-missing` passes vacuously if SHA256SUMS lists
  # nothing we downloaded. Confirm baize is actually named in it before
  # trusting a pass -- otherwise a truncated or empty SHA256SUMS would let
  # an unverified binary through. (Mirrors install.sh's verify(); see the
  # paired-change surface note above resolve_latest_version -- if this
  # guard changes, mirror it there too.)
  grep -q '[[:space:]]baize$' "$tmp/SHA256SUMS" || {
    printf 'baize update: SHA256SUMS does not list baize. Refusing to update.\n' >&2
    return 1
  }

  # SHA256SUMS travels the same HTTPS channel as baize itself, so this
  # catches a truncated or corrupted download -- not a MITM or a
  # compromised release. The real trust anchor is GitHub's TLS plus the
  # account; this is integrity, not a signature.
  if ! ( cd "$tmp" && sha256sum -c --ignore-missing SHA256SUMS ) >/dev/null 2>&1; then
    printf 'baize update: checksum verification FAILED. Refusing to update.\n' >&2
    return 1
  fi

  chmod +x "$tmp/baize"

  # Self-test before anything on disk is touched. `check` is the right
  # choice: it exercises config loading, path resolution, and df parsing
  # while provably sending nothing -- proof the candidate can actually run
  # on this host, not just that its bytes matched a checksum.
  local candidate_version
  candidate_version="$("$tmp/baize" version 2>/dev/null)" || candidate_version=""
  if [[ ! "$candidate_version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
    printf 'baize update: downloaded baize failed its self-test (version). Refusing to update.\n' >&2
    return 1
  fi
  if ! "$tmp/baize" check >/dev/null 2>&1; then
    printf 'baize update: downloaded baize failed its self-test (check). Refusing to update.\n' >&2
    return 1
  fi

  if ! cp -f "$(bin_path)" "$HOME/.local/bin/baize.prev"; then
    printf 'baize update: could not back up the current binary; aborting before swap.\n' >&2
    return 1
  fi

  # The only atomic step in this whole sequence -- everything above is
  # preparation, everything below is verifying what just happened.
  if ! mv -f "$tmp/baize" "$(bin_path)"; then
    printf 'baize update: could not move the new binary into place.\n' >&2
    return 1
  fi

  if ! "$(bin_path)" version >/dev/null 2>&1; then
    rollback_update || true
    return 1
  fi

  printf 'Updated baize %s -> %s\n' "$BAIZE_VERSION" "$target_norm"
  printf 'Previous version kept at ~/.local/bin/baize.prev\n'
}

# --- Usage / dispatch ----------------------------------------------------------

usage() {
  cat <<'EOF'
baize install [--dsn URL] [--threshold 85] [--interval 15m] [--heartbeat URL] [--dry-run]
baize remove          Unwire cron, remove files, announce departure
baize check           Run once, print result, send nothing
baize run             Cron verb: check, alert on transitions, heartbeat
baize test            Send a synthetic event to verify DSN and network
baize status          Show config, cron state, last alert, available update
baize update          Explicitly update to the latest release
baize version         Print version
EOF
}

main() {
  local verb="${1:-}"; shift || true
  case "$verb" in
    install) cmd_install "$@" ;;
    remove)  cmd_remove "$@" ;;
    check)   cmd_check "$@" ;;
    run)     cmd_run "$@" ;;
    test)    cmd_test "$@" ;;
    status)  cmd_status "$@" ;;
    update)  cmd_update "$@" ;;
    version|--version|-v) printf 'baize %s\n' "$BAIZE_VERSION" ;;
    help|--help|-h|"") usage ;;
    *) printf 'baize: unknown command: %s\n' "$verb" >&2; usage >&2; exit 2 ;;
  esac
}

if [[ -z "${BAIZE_LIB_ONLY:-}" ]]; then
  main "$@"
fi
