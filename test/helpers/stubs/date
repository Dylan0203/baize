#!/usr/bin/env bash
# Stub for date: if BAIZE_STUB_NOW is set and the args are exactly "+%s",
# print BAIZE_STUB_NOW; otherwise delegate to the real date so other
# formats (e.g. TZ=UTC printf builtin does not call this at all) still work.
set -euo pipefail

if [[ -n "${BAIZE_STUB_NOW:-}" && "$#" -eq 1 && "$1" == "+%s" ]]; then
  printf '%s\n' "$BAIZE_STUB_NOW"
  exit 0
fi

exec /bin/date "$@"
