#!/usr/bin/env bash
# Stub for df -P: prints a df -P-shaped table whose used percentage comes
# from BAIZE_STUB_DF_PCT (default 10), for whichever mount was requested.
set -euo pipefail

pct="${BAIZE_STUB_DF_PCT:-10}"
mount="${*: -1}"

printf 'Filesystem     1024-blocks     Used Available Capacity Mounted on\n'
printf '/dev/stub          10485760  1048576   9437184      %s%% %s\n' "$pct" "$mount"
